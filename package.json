{
  "name": "t-stack-manager",
  "version": "0.1.4",
  "description": "Remember your project setups: scaffold from saved better-t-stack templates and reapply the libraries, post-scaffold modifications, and agent skills you always add. A Claude Code skill backed by a TypeScript CLI.",
  "keywords": [
    "better-t-stack",
    "claude-code",
    "cli",
    "cursor",
    "scaffold",
    "skill",
    "template",
    "typescript"
  ],
  "homepage": "https://github.com/sebastianwd/t-stack-manager",
  "license": "Apache-2.0",
  "author": "sebastianwd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebastianwd/t-stack-manager.git"
  },
  "bin": {
    "t-stack-manager": "dist/cli/bin.mjs"
  },
  "files": [
    "dist",
    "defaults",
    "skill",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsx scripts/build.ts",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt src scripts tests",
    "prepublishOnly": "pnpm build",
    "changeset": "changeset",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "@better-t-stack/types": "^3.30.3",
    "execa": "^9.6.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.10.0",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "tsdown": "^0.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
